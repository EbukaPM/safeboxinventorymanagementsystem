# SafeBox Energy IMS — Environment Variables
# Copy this file to .env and update values before deployment

# Server
PORT=3001
NODE_ENV=development

# JWT Secret — CHANGE THIS to a long random string in production
JWT_SECRET=safebox-energy-super-secret-jwt-key-change-in-production

# JWT expiry
JWT_EXPIRES_IN=8h

# Database path (SQLite)
DB_PATH=./server/db/safebox.db

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Company defaults
COMPANY_NAME=SafeBox Energy
COMPANY_EMAIL=info@safebox.ng
